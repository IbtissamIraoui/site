function openCheckout() { if(cart.length===0)return; closeCart(); showFormView(); renderModalSummary(); document.getElementById('modal-overlay').classList.add('open'); }
function closeModal() { document.getElementById('modal-overlay').classList.remove('open'); }
function closeOnOverlay(e) { if(e.target===document.getElementById('modal-overlay')) closeModal(); }

function renderModalSummary() {
  const rows=cart.map(i=>`<div class="modal-order-row"><span><img src="${i.img}" style="width:20px;height:20px;object-fit:cover;border-radius:3px;margin-right:8px;vertical-align:middle">${i.name} × ${i.quantity}</span><span>${i.price*i.quantity} MAD</span></div>`).join('');
  document.getElementById('modal-summary').innerHTML=rows+`<div class="modal-order-total"><span>Total</span><span>${getTotal()} MAD</span></div>`;
}

function selectPayment(method) {
  selectedPayment=method;
  ['card','paypal','cod','virement'].forEach(m=>{document.getElementById(`pay-${m}`).classList.toggle('selected',m===method);});
  document.getElementById('stripe-fields').classList.toggle('visible',method==='card');
  document.getElementById('err-payment').textContent='';
}
function formatCard(input) { let v=input.value.replace(/\D/g,'').substring(0,16); input.value=v.match(/.{1,4}/g)?.join(' ')||v; }

function validate() {
  let valid=true;
  const setErr=(id,msg)=>{document.getElementById(id).textContent=msg;if(msg)valid=false;};
  const val=id=>document.getElementById(id).value.trim();
  setErr('err-firstname',val('f-firstname')?'':'Prénom requis');
  setErr('err-lastname',val('f-lastname')?'':'Nom requis');
  setErr('err-email',/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(val('f-email'))?'':'Email invalide');
  setErr('err-phone',val('f-phone')?'':'Téléphone requis');
  setErr('err-address',val('f-address')?'':'Adresse requise');
  setErr('err-payment',selectedPayment?'':'Choisissez un paiement');
  return valid;
}

async function submitOrder() {
  if(!validate()) return;
  const btn=document.getElementById('submit-btn'); btn.disabled=true; btn.classList.add('loading');
  const orderId='ORD-'+Date.now()+'-'+Math.random().toString(36).substr(2,5).toUpperCase();
  const firstName=document.getElementById('f-firstname').value.trim();
  const lastName=document.getElementById('f-lastname').value.trim();
  const email=document.getElementById('f-email').value.trim();
  const phone=document.getElementById('f-phone').value.trim();
  const address=document.getElementById('f-address').value.trim();

  try {
    if(supabaseClient) {
      // Insert customer
      const { data: customer, error: custErr } = await supabaseClient
        .from('customers')
        .insert([{ name:`${firstName} ${lastName}`, email, phone, address }])
        .select().single();
      if(custErr) throw custErr;

      // Insert order
      const { error: ordErr } = await supabaseClient.from('orders').insert([{
        id: orderId,
        customer_id: customer.id,
        total: getTotal(),
        payment: selectedPayment,
        pay_status: 'pending',
        status: 'pending'
      }]);
      if(ordErr) throw ordErr;

      // Insert order items
      const items = cart.map(i=>({ order_id:orderId, product_id:i.product_id, qty:i.quantity, unit_price:i.price }));
      const { error: itemErr } = await supabaseClient.from('order_items').insert(items);
      if(itemErr) throw itemErr;

      // Update stock
      for(const item of cart) {
        const p = PRODUCTS.find(x=>x.id===item.product_id);
        if(p) {
          await supabaseClient.from('products').update({ stock: p.stock - item.quantity }).eq('id', item.product_id);
        }
      }
    }

    // n8n webhook (optionnel)
    const webhookUrl = CONFIG.n8nWebhookUrl;
    if(webhookUrl && !webhookUrl.includes('your-n8n')) {
      const payload = {
        order_id:orderId, customer:{name:`${firstName} ${lastName}`,email,phone,address},
        items:cart.map(i=>({product_id:i.product_id,quantity:i.quantity,price:i.price})),
        total:getTotal(), payment_method:selectedPayment, currency:'MAD'
      };
      fetch(webhookUrl,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)}).catch(()=>{});
    }

    document.getElementById('success-order-id').textContent=orderId;
    showSuccessView();
  } catch(err) {
    console.error('Order error:', err);
    showErrorView(err.message || 'Erreur lors de la commande.');
  }
  btn.disabled=false; btn.classList.remove('loading');
}

