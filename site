    { id:'P011', name:'Set de Cuisine', img:'https://images.unsplash.com/photo-1603006905003-be475563bc59?w=300&h=400&fit=crop', price:320, originalPrice:400, stock:15, badge:'Éco', badgeClass:'badge-eco', category:'Cuisine', rating:4.5, reviews:156, description:'Set complet de cuisine en inox.' },
    { id:'P012', name:'Lampe de Table', img:'https://images.unsplash.com/photo-1615800001964-5e4c80a8a2b8?w=300&h=400&fit=crop', price:280, originalPrice:360, stock:8, badge:null, badgeClass:'', category:'Décoration', rating:4.6, reviews:112, description:'Lampe de table en bois recyclé.' },
  ];
