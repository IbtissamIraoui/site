};

function loadConfig() {
  try {
    const saved = localStorage.getItem('maison_nova_config');
    if(saved) CONFIG = {...CONFIG, ...JSON.parse(saved)};
  } catch(e) {}
  // Pre-fill config panel
  document.getElementById('cfg-supabase-url').value = CONFIG.supabaseUrl;
  document.getElementById('cfg-supabase-key').value = CONFIG.supabaseKey;
  document.getElementById('cfg-ollama-url').value   = CONFIG.ollamaUrl;
