// =============================================
//  CHATBOT OLLAMA
// =============================================
let chatHistory = [];
let chatOpen = false;
let ollamaOnline = false;
let isChatting = false;

function toggleChat() {
  chatOpen = !chatOpen;
  document.getElementById('chat-window').classList.toggle('open', chatOpen);
  if(chatOpen) {
    document.getElementById('chat-notif').style.display='none';
    if(chatHistory.length === 0) addWelcomeMessage();
    document.getElementById('chat-input').focus();
    checkOllama();
  }
}

function addWelcomeMessage() {
  addBotMessage("Bonjour ! 👋 Je suis **Nova**, votre assistant IA MAISON NOVA.\n\nJe peux vous aider à trouver des produits, vérifier les stocks, ou répondre à vos questions. Comment puis-je vous aider ?");
}

async function checkOllama() {
  const dot = document.getElementById('ollama-dot');
  const statusText = document.getElementById('ollama-status-text');
  try {
    const res = await fetch(`${CONFIG.ollamaUrl}/api/tags`, { signal: AbortSignal.timeout(3000) });
    if(res.ok) {
      ollamaOnline = true;
      dot.className = 'ollama-dot online';
      statusText.textContent = `Ollama en ligne · ${CONFIG.ollamaModel}`;
    } else { throw new Error(); }
  } catch(e) {
    ollamaOnline = false;
    dot.className = 'ollama-dot offline';
    statusText.textContent = 'Ollama hors ligne — mode réponses automatiques';
  }
}

function buildSystemPrompt() {
  const productList = PRODUCTS.slice(0,20).map(p =>
    `- ${p.name} (${p.id}): ${p.price} MAD, stock: ${p.stock}, catégorie: ${p.category}${p.badge?', badge: '+p.badge:''}`
  ).join('\n');
  const cartInfo = cart.length > 0
    ? cart.map(i=>`${i.name} x${i.quantity}`).join(', ')
    : 'panier vide';

  return `Tu es Nova, l'assistant IA de la boutique MAISON NOVA, spécialisée dans l'artisanat marocain premium.
Tu es amical, concis et utile. Tu réponds en français.
Tu aides les clients à trouver des produits, comprendre les disponibilités, et finaliser leurs achats.

CATALOGUE ACTUEL (${PRODUCTS.length} produits):
${productList}

PANIER CLIENT: ${cartInfo}

RÈGLES:
- Réponds toujours en français
- Sois concis (max 3-4 phrases sauf si demande détaillée)
- Si un produit est en rupture (stock=0), propose des alternatives
- Pour ajouter au panier, dis "tapez sur le produit ou utilisez le bouton Ajouter"
- Livraison: gratuite, 3-5 jours ouvrés au Maroc
- Retours: 30 jours
- Paiements acceptés: carte, PayPal, à la livraison, virement`;
}

async function sendChatMessage() {
  const input = document.getElementById('chat-input');
  const msg = input.value.trim();
  if(!msg || isChatting) return;
  input.value = ''; input.style.height='auto';
  addUserMessage(msg);
  isChatting = true;
  document.getElementById('chat-send').disabled = true;

  if(ollamaOnline) {
    await sendToOllama(msg);
  } else {
    await sendFallbackResponse(msg);
  }
  isChatting = false;
  document.getElementById('chat-send').disabled = false;
}

async function sendToOllama(userMsg) {
  showTyping();
  chatHistory.push({ role: 'user', content: userMsg });

  try {
    const body = {
      model: CONFIG.ollamaModel,
      messages: [
        { role: 'system', content: buildSystemPrompt() },
        ...chatHistory
      ],
      stream: false
    };
    const res = await fetch(`${CONFIG.ollamaUrl}/api/chat`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body),
      signal: AbortSignal.timeout(30000)
    });
    if(!res.ok) throw new Error(`HTTP ${res.status}`);
    const data = await res.json();
    const reply = data.message?.content || data.response || "Désolé, je n'ai pas pu répondre.";
    chatHistory.push({ role: 'assistant', content: reply });
    hideTyping();
    addBotMessage(reply);
  } catch(e) {
    hideTyping();
    ollamaOnline = false;
    document.getElementById('ollama-dot').className = 'ollama-dot offline';
    document.getElementById('ollama-status-text').textContent = 'Ollama déconnecté — mode automatique';
    await sendFallbackResponse(userMsg);
  }
}

async function sendFallbackResponse(userMsg) {
  showTyping();
  await new Promise(r => setTimeout(r, 800 + Math.random()*600));
  hideTyping();

  const msg = userMsg.toLowerCase();
  let reply = '';

  // Smart keyword matching
  if(msg.match(/stock|disponible|dispo/)) {
    const available = PRODUCTS.filter(p=>p.stock>0);
    const low = PRODUCTS.filter(p=>p.stock>0&&p.stock<=5);
    reply = `📦 **${available.length}/${PRODUCTS.length}** produits disponibles. ${low.length > 0 ? `⚠️ Stock limité: ${low.map(p=>p.name).join(', ')}.` : ''} Besoin d'info sur un produit précis ?`;
  } else if(msg.match(/prix|coût|tarif|cher|pas cher|moins cher/)) {
    const sorted = [...PRODUCTS].filter(p=>p.stock>0).sort((a,b)=>a.price-b.price);
    reply = `💰 Nos produits vont de **${sorted[0]?.price} MAD** (${sorted[0]?.name}) à **${sorted[sorted.length-1]?.price} MAD**. Le meilleur rapport qualité/prix : ${sorted.slice(0,3).map(p=>`${p.name} à ${p.price} MAD`).join(', ')}.`;
  } else if(msg.match(/livraison|délai|expedition|envoyer/)) {
    reply = '🚚 **Livraison gratuite** partout au Maroc ! Délai : **3-5 jours ouvrés**. Suivi de commande inclus. Vous recevrez un SMS de confirmation.';
  } else if(msg.match(/retour|rembourse|échange/)) {
    reply = '↩️ Retours acceptés sous **30 jours** sans justification. Remboursement complet ou échange. Contactez-nous à admin@maisonova.ma.';
  } else if(msg.match(/panier|commande en cours/)) {
    if(cart.length === 0) {
      reply = '🛒 Votre panier est vide. Parcourez notre catalogue pour découvrir nos produits artisanaux !';
    } else {
      reply = `🛒 Votre panier contient **${cart.length} produit${cart.length>1?'s':''}** pour un total de **${getTotal()} MAD**. ${cart.map(i=>`${i.name} x${i.quantity}`).join(', ')}.`;
    }
  } else if(msg.match(/paiement|payer|carte|cod|livraison/)) {
    reply = '💳 Nous acceptons : **carte bancaire**, **PayPal**, **paiement à la livraison (COD)**, et **virement bancaire**. Toutes les transactions sont sécurisées 🔒';
  } else if(msg.match(/promotion|promo|offre|solde|reduction|réduction|-/)) {
    const promos = PRODUCTS.filter(p=>p.originalPrice>p.price&&p.stock>0).sort((a,b)=>(b.originalPrice-b.price)-(a.originalPrice-a.price));
    if(promos.length > 0) {
      reply = `🎉 Meilleures offres actuelles :\n${promos.slice(0,3).map(p=>`• **${p.name}** : ${p.price} MAD (au lieu de ${p.originalPrice} MAD, -${Math.round((1-p.price/p.originalPrice)*100)}%)`).join('\n')}`;
    } else {
      reply = "🎉 Consultez notre barre promo en haut de page pour les offres du jour !";
    }
  } else if(msg.match(/decoration|déco|vase|miroir|lampe|panier/)) {
    const prods = PRODUCTS.filter(p=>p.category==='Décoration'&&p.stock>0);
    reply = `🏺 Décoration (${prods.length} produits) : ${prods.map(p=>`**${p.name}** à ${p.price} MAD`).join(', ')}.`;
  } else if(msg.match(/textile|coussin|tapis/)) {
    const prods = PRODUCTS.filter(p=>p.category==='Textile'&&p.stock>0);
    reply = `🧶 Textile (${prods.length} produits) : ${prods.map(p=>`**${p.name}** à ${p.price} MAD`).join(', ')}.`;
  } else if(msg.match(/cuisine|theiere|théière|set/)) {
    const prods = PRODUCTS.filter(p=>p.category==='Cuisine'&&p.stock>0);
    reply = `🍽️ Cuisine (${prods.length} produits) : ${prods.map(p=>`**${p.name}** à ${p.price} MAD`).join(', ')}.`;
  } else if(msg.match(/bien.?etre|bien être|bougie|diffuseur/)) {
    const prods = PRODUCTS.filter(p=>p.category==='Bien-être'&&p.stock>0);
    reply = `🕯️ Bien-être (${prods.length} produits) : ${prods.map(p=>`**${p.name}** à ${p.price} MAD`).join(', ')}.`;
  } else if(msg.match(/bonjour|salut|hello|bonsoir|hi/)) {
    reply = `Bonjour ! 😊 Bienvenue chez **MAISON NOVA**. Je suis Nova, votre assistante. Comment puis-je vous aider aujourd'hui ?`;
  } else if(msg.match(/merci|thank/)) {
    reply = "Avec plaisir ! 😊 N'hésitez pas si vous avez d'autres questions. Bonne visite sur MAISON NOVA !";
  } else {
    const randomProd = PRODUCTS.filter(p=>p.stock>0)[Math.floor(Math.random()*PRODUCTS.filter(p=>p.stock>0).length)];
    reply = `Bonne question ! 🤔 Je suis Nova, l'assistant de MAISON NOVA. Pour l'activer avec l'IA Ollama, configurez-le via le bouton **"Supabase"** en haut.\n\nEn attendant : coup de cœur du jour → **${randomProd?.name}** à ${randomProd?.price} MAD !`;
  }
  addBotMessage(reply);
}

function addUserMessage(msg) {
  const div = document.createElement('div');
  div.className = 'chat-msg user';
  div.innerHTML = `
    <div class="msg-avatar">👤</div>
    <div>
      <div class="msg-bubble">${escapeHtml(msg)}</div>
      <div class="msg-time">${new Date().toLocaleTimeString('fr',{hour:'2-digit',minute:'2-digit'})}</div>
    </div>`;
  appendChatMsg(div);
}

function addBotMessage(msg) {
  const div = document.createElement('div');
  div.className = 'chat-msg bot';
  div.innerHTML = `
    <div class="msg-avatar">🤖</div>
    <div>
      <div class="msg-bubble">${formatMd(msg)}</div>
      <div class="msg-time">${new Date().toLocaleTimeString('fr',{hour:'2-digit',minute:'2-digit'})}</div>
    </div>`;
  appendChatMsg(div);
}

function showTyping() {
  const div = document.createElement('div');
  div.className = 'chat-msg bot'; div.id = 'typing-indicator';
  div.innerHTML = `<div class="msg-avatar">🤖</div><div class="msg-bubble chat-typing"><div class="typing-dot"></div><div class="typing-dot"></div><div class="typing-dot"></div></div>`;
  appendChatMsg(div);
}
function hideTyping() { document.getElementById('typing-indicator')?.remove(); }

function appendChatMsg(el) {
  const msgs = document.getElementById('chat-messages');
  msgs.appendChild(el);
  msgs.scrollTop = msgs.scrollHeight;
}

function clearChat() {
  chatHistory = [];
  document.getElementById('chat-messages').innerHTML = '';
  addWelcomeMessage();
}

function sendSuggestion(el) {
  document.getElementById('chat-input').value = el.textContent.replace(/^[^\s]+ /, '');
  sendChatMessage();
}

function handleChatKey(e) {
  if(e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendChatMessage(); }
}

function autoResize(el) {
  el.style.height = 'auto';
  el.style.height = Math.min(el.scrollHeight, 100) + 'px';
}

function escapeHtml(text) {
  return text.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

function formatMd(text) {
  return text
    .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
    .replace(/\*(.*?)\*/g, '<em>$1</em>')
    .replace(/\n/g, '<br>');
}

