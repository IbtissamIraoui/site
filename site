}

function saveConfig() {
  CONFIG.supabaseUrl   = document.getElementById('cfg-supabase-url').value.trim();
  CONFIG.supabaseKey   = document.getElementById('cfg-supabase-key').value.trim();
  CONFIG.ollamaUrl     = document.getElementById('cfg-ollama-url').value.trim() || 'http://localhost:11434';
  CONFIG.ollamaModel   = document.getElementById('cfg-ollama-model').value.trim() || 'llama3.2';
  CONFIG.n8nWebhookUrl = document.getElementById('cfg-n8n-url').value.trim();
  try { localStorage.setItem('maison_nova_config', JSON.stringify(CONFIG)); } catch(e) {}
  document.getElementById('chat-model-label').textContent = `Propulsé par Ollama · ${CONFIG.ollamaModel}`;
  closeConfig();
  initSupabase();
  checkOllama();
  showToast('✅ Configuration sauvegardée');
}

function openConfig() {
  document.getElementById('config-panel').classList.add('open');
  document.getElementById('config-overlay').classList.add('open');
}
function closeConfig() {
  document.getElementById('config-panel').classList.remove('open');
  document.getElementById('config-overlay').classList.remove('open');
}

// =============================================
//  SUPABASE
// =============================================
let supabaseClient = null;
let PRODUCTS = [];
let filteredProducts = [];

function initSupabase() {
  if(!CONFIG.supabaseUrl || !CONFIG.supabaseKey) {
    setDbStatus('disconnected', 'Non configuré');
    loadFallbackProducts();
    return;
  }
  try {
    supabaseClient = window.supabase.createClient(CONFIG.supabaseUrl, CONFIG.supabaseKey);
    setDbStatus('connecting', 'Connexion...');
    loadProducts();
    subscribeRealtime();
  } catch(e) {
    setDbStatus('error', 'Erreur connexion');
    loadFallbackProducts();
  }
}

function setDbStatus(state, label) {
  const el = document.getElementById('db-status');
  el.className = 'db-status';
  if(state === 'connected') el.classList.add('connected');
  if(state === 'error') el.classList.add('error');
  document.getElementById('db-status-text').textContent = label;
}

async function loadProducts() {
  try {
    const { data, error } = await supabaseClient.from('products').select('*').order('id');
    if(error) throw error;
    PRODUCTS = data.map(p => ({
      id: p.id,
      name: p.name,
      img: p.img || 'https://images.unsplash.com/photo-1578662996442-48f60103fc96?w=300&h=400&fit=crop',
      price: p.price,
      originalPrice: p.original_price || p.price,
      stock: p.stock,
      badge: p.badge || null,
      badgeClass: getBadgeClass(p.badge),
      category: p.category || 'Divers',
      rating: 4.5 + Math.random()*0.5,
      reviews: Math.floor(50 + Math.random()*300),
      description: p.description || ''
    }));
    filteredProducts = [...PRODUCTS];
    setDbStatus('connected', `Connecté (${PRODUCTS.length})`);
    document.getElementById('products-subtitle').textContent = `${PRODUCTS.length} produits · Artisanat marocain premium`;
    renderProducts();
  } catch(e) {
    setDbStatus('error', 'Erreur DB');
    loadFallbackProducts();
    console.error('Supabase error:', e);
  }
}

function getBadgeClass(badge) {
  if(!badge) return '';
  const b = badge.toLowerCase();
  if(b.includes('nouveau') || b.includes('new')) return 'badge-new';
  if(b.includes('best') || b.includes('populaire')) return 'badge-best';
  if(b.includes('limite') || b.includes('artisanal')) return 'badge-limited';
  if(b.includes('eco') || b.includes('éco')) return 'badge-eco';
  return 'badge-sale';
}

function subscribeRealtime() {
  if(!supabaseClient) return;
  supabaseClient.channel('products-changes')
    .on('postgres_changes', { event: '*', schema: 'public', table: 'products' }, payload => {
      loadProducts();
      showToast('🔄 Catalogue mis à jour');
    })
    .subscribe();
}

